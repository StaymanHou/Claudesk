# Read-only reference symlinks to companion repos
_ref/

# Homebrew tap — its own independent git repo (StaymanHou/homebrew-claudesk),
# nested here for filesystem tidiness but NOT tracked by this (canonical) repo.
# The /release skill bumps its cask on each release.
homebrew-claudesk/

# Global-scope learning drafts (hand-curated, never auto-committed)
.claude/learnings/

# Per-machine Claude Code state (NOT shared between developers)
.claude/settings.local.json

# Transient session pointer (deleted on resume)
workflow/.session.md

# Test result artifacts (regenerable)
tests/results/*.json

# Python caches (canonical artifact-tracking-policy lines; no Python in-tree today)
__pycache__/
*.pyc

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build / runtime
node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.playwright-mcp/

# Machine-local scratch: throwaway projects used to drive verify-self (each is its
# own git repo). Per the GLOBAL artifact-tracking MAP, tmp/ is ignore-by-default.
tmp/

# Transient updater manifest produced at repo root by the /release skill (step 5b),
# uploaded to the GH release, then removed at step 12. Ignored so a mid-release run
# never trips the skill's own clean-working-tree precondition and it's never committed.
/latest.json
